  "keyFeatures": [
    "Send SMS via REST API with SenderID support",
    "Rich Communication Services (RCS) messaging with cards, carousels, and suggestions",
    "Truecaller messaging for branded in-call notifications",
    "Contact and group management via API",
    "Message delivery status tracking",
    "Account balance checking",
    "Callback/webhook support for delivery notifications"
  ],
  "publicApiSurface": [
    "POST /api/v1/send-sms",
    "POST /api/v1/send-rcs",
    "POST /api/v1/send-truecaller",
    "GET /api/v1/status/{message_id}",
    "GET /api/v1/rcs/check-capability/{phone}",
    "GET /api/v1/balance",
    "GET /api/v1/groups",
    "GET /api/v1/group-contacts/{groupid}",
    "POST /api/v1/create-group",
    "POST /api/v1/add-contact",
    "POST /api/v1/add-contacts",
    "POST /api/v1/update-contact/{contactid}"
  ]
